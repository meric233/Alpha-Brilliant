VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# App Check (optional until launch). reCAPTCHA v3 SITE key (public; safe in client).
# When set, the app initializes App Check to protect the OpenAI proxy from abuse.
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key
# Local dev only: an App Check debug token registered in Firebase console.
# Leave unset to have the SDK print a fresh debug token to the console on load.
VITE_APPCHECK_DEBUG_TOKEN=
